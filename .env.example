# ─── App Settings ────────────────────────────────────────────────────────────
PORT=3000
TIMEZONE=Asia/Karachi
DAILY_CUTOFF_TIME=17:00
KM_MIN=0
KM_MAX=200
REMINDER_DELAY_HOURS=24
DUPLICATE_POLICY=average

# ─── Scheduler Times ─────────────────────────────────────────────────────────
FPU_CHECK_TIME=10:00
LDO_CHECK_TIME=15:00
SUMMARY_TIME=18:00

# ─── Google Sheets (OAuth — run: node scripts/authorize.js) ───────────────────
GOOGLE_SHEET_ID=your-km-tracking-sheet-id
GOOGLE_SHEET_NAME=KM Records
LOGISTICS_SHEET_ID=your-logistics-sheet-id
LOGISTICS_SHEET_TAB=Niete dedicated fleet

# ─── Gemini Vision ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ─── Manager Contact ─────────────────────────────────────────────────────────
MANAGER_EMAIL=your-email@example.com
